{
  "rulebook_id": "junior_v1",
  "league_type": "junior",
  "version": "1.0",
  "roster_rules": {
    "min_roster": 26,
    "max_roster": 26,
    "active_roster": 26,
    "goalies_required": 2,
    "overage_slots": 3,
    "import_slots": 2,
    "injured_reserve_enabled": true,
    "reserve_list_enabled": true
  },
  "eligibility_rules": {
    "min_age": 15,
    "max_age": 20
  },
  "contract_rules": {
    "allowed_contract_types": [
      "junior_player_agreement",
      "staff_contract",
      "gm_contract",
      "scout_contract",
      "coach_contract"
    ],
    "salary_cap_enabled": false,
    "junior_stipends_enabled": true,
    "education_packages_enabled": true,
    "housing_support_enabled": true,
    "no_trade_clauses_enabled": false,
    "no_move_clauses_enabled": false,
    "arbitration_enabled": false,
    "offer_sheets_enabled": false
  },
  "draft_rules": {
    "draft_enabled": true,
    "rounds": 15,
    "draft_order": "reverse_standings"
  },
  "playoff_rules": {
    "teams_qualify": 8,
    "series_format": [
      7,
      7,
      7
    ],
    "reseed_each_round": true
  },
  "budget_rules": {
    "owner_budget_enabled": true,
    "hard_salary_cap_enabled": false
  },
  "staff_rules": {
    "position_limits": [
      {
        "role": "GeneralManager",
        "department": "Executive",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "AssistantGM",
        "department": "Executive",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "HeadCoach",
        "department": "Coaching",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "AssistantCoach",
        "department": "Coaching",
        "minimum": 2,
        "maximum": 2
      },
      {
        "role": "DevelopmentCoach",
        "department": "Coaching",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "HeadScout",
        "department": "Scouting",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "Scout",
        "department": "Scouting",
        "minimum": 3,
        "maximum": 3
      },
      {
        "role": "HeadAthleticTherapist",
        "department": "Medical",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "TeamDoctor",
        "department": "Medical",
        "minimum": 1,
        "maximum": 1
      },
      {
        "role": "HeadEquipmentManager",
        "department": "Equipment",
        "minimum": 1,
        "maximum": 1
      }
    ]
  },
  "season_rules": {
    "season_start_month": 9,
    "season_start_day": 1,
    "training_camp_offset_days": 0,
    "season_begin_offset_days": 21,
    "trade_deadline_offset_days": 140,
    "playoffs_begin_offset_days": 210,
    "championship_offset_days": 250,
    "awards_offset_days": 258,
    "recruiting_open_offset_days": 265,
    "recruiting_close_offset_days": 290,
    "draft_lottery_offset_days": 292,
    "draft_offset_days": 300,
    "free_agency_open_offset_days": 310,
    "free_agency_close_offset_days": 330
  },
  "buyout_rules": {
    "buyouts_enabled": false,
    "buyout_window_start_offset_days": 0,
    "buyout_window_end_offset_days": 0,
    "buyout_cost_percentage": 0,
    "penalty_years_multiplier": 0,
    "age_based_cost_rule_placeholder": "Junior-style rulebook disables contract buyouts unless a custom rulebook enables them.",
    "cap_penalty_enabled": false,
    "minimum_contract_remaining_years": 0
  },
  "offer_sheet_rules": {
    "offer_sheets_enabled": false,
    "eligible_rights_statuses": [],
    "compensation_thresholds": [],
    "response_window_days": 0,
    "required_draft_pick_ownership": false,
    "matching_rules": "disabled",
    "cap_validation_enabled": false,
    "arbitration_blocks_offer_sheets": true
  }
}
